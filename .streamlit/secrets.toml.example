# Copy these values into Streamlit Community Cloud secrets.
# Do not commit a real .streamlit/secrets.toml file.

GROQ_API_KEY = "your_groq_key_here"
GROQ_MODEL = "llama-3.3-70b-versatile"

# Optional Gemini fallback
GEMINI_API_KEY = "your_gemini_key_here"

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace_with_a_long_random_secret"

[auth.google]
client_id = "your_google_client_id"
client_secret = "your_google_client_secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Never paste real keys into GitHub.
# In Streamlit Community Cloud, add these values under App settings -> Secrets.
